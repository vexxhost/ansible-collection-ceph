{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>vexxhost/.github"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^\\.zuul\\.yaml$"],
      "matchStrings": [
        "ceph_version:\\s*(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "ceph/ceph",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ]
}
